{
  "additionalProperties": false,
  "description": "MCTP success response: truth.getEntities",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "properties": {
    "jsonrpc": {
      "const": "2.0",
      "type": "string"
    },
    "id": {
      "description": "JSON-RPC correlation id (string or integer, never null).",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ]
    },
    "result": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "count",
        "entities"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "screenChanged": {
          "type": "boolean"
        },
        "tookMs": {
          "type": "number"
        },
        "serverTick": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "count": {
          "type": "integer"
        },
        "entities": {
          "type": "array",
          "items": {
            "additionalProperties": false,
            "description": "Authoritative entity descriptor.",
            "type": "object",
            "required": [
              "id",
              "type",
              "position"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "uuid": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "position": {
                "additionalProperties": false,
                "description": "World-space position (doubles).",
                "type": "object",
                "required": [
                  "x",
                  "y",
                  "z"
                ],
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  },
                  "z": {
                    "type": "number"
                  }
                }
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "customNameRaw": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
