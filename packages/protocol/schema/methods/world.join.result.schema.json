{
  "additionalProperties": false,
  "description": "MCTP success response: world.join",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "properties": {
    "jsonrpc": {
      "const": "2.0",
      "type": "string"
    },
    "id": {
      "description": "JSON-RPC correlation id (string or integer, never null).",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ]
    },
    "result": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "screenChanged": {
          "type": "boolean"
        },
        "tookMs": {
          "type": "number"
        },
        "serverTick": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "playerName": {
          "type": "string"
        },
        "playerUuid": {
          "type": "string"
        },
        "dimension": {
          "type": "string"
        },
        "position": {
          "additionalProperties": false,
          "description": "World-space position (doubles).",
          "type": "object",
          "required": [
            "x",
            "y",
            "z"
          ],
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "z": {
              "type": "number"
            }
          }
        },
        "serverBrand": {
          "type": "string"
        }
      }
    }
  }
}
