                      {
                        "const": "slot",
                        "type": "string"
                      },
                      {
                        "const": "label",
                        "type": "string"
                      },
                      {
                        "const": "input",
                        "type": "string"
                      },
                      {
                        "const": "tab",
                        "type": "string"
                      },
                      {
                        "const": "list",
                        "type": "string"
                      },
                      {
                        "const": "listItem",
                        "type": "string"
                      }
                    ]
                  },
                  "label": {
                    "type": "string"
                  },
                  "text": {
                    "type": "string"
                  },
                  "rawLabel": {
                    "type": "string"
                  },
                  "bodyText": {
                    "type": "string"
                  },
                  "lore": {
                    "type": "array",
