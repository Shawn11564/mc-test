                      },
                      "w": {
                        "type": "integer"
                      },
                      "h": {
                        "type": "integer"
                      }
                    }
                  },
                  "screenId": {
                    "type": "string"
                  },
                  "index": {
                    "type": "integer"
                  },
                  "enabled": {
                    "type": "boolean"
                  },
                  "visible": {
                    "type": "boolean"
                  },
                  "ref": {
                    "type": "string"
                  }
