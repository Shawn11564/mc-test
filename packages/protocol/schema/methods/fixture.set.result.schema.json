    "id",
    "result"
  ],
  "properties": {
    "jsonrpc": {
      "const": "2.0",
      "type": "string"
    },
    "id": {
      "description": "JSON-RPC correlation id (string or integer, never null).",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ]
    },
    "result": {
