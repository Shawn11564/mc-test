            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fixture": {
          "type": "string"
        },
        "applied": {
          "type": "boolean"
        },
        "handle": {
          "type": "string"
        },
        "result": {
          "description": "Free-form by-name JSON object.",
          "type": "object",
          "patternProperties": {
            "^(.*)$": {}
          }
