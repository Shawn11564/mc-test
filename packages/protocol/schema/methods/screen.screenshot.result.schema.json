{
  "additionalProperties": false,
  "description": "MCTP success response: screen.screenshot",
  "type": "object",
  "required": [
    "jsonrpc",
    "id",
    "result"
  ],
  "properties": {
    "jsonrpc": {
      "const": "2.0",
      "type": "string"
    },
    "id": {
      "description": "JSON-RPC correlation id (string or integer, never null).",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ]
    },
    "result": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "image"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "screenChanged": {
          "type": "boolean"
        },
        "tookMs": {
          "type": "number"
        },
        "serverTick": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "image": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "format",
            "width",
            "height"
          ],
          "properties": {
            "format": {
              "type": "string"
            },
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            },
            "encoding": {
              "const": "base64",
              "type": "string"
            },
            "data": {
              "type": "string"
            },
            "ref": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
