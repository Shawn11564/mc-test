{
  "additionalProperties": false,
  "description": "JSON-RPC 2.0 error object.",
  "type": "object",
  "required": [
    "code",
    "message"
  ],
  "properties": {
    "code": {
      "type": "integer"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "additionalProperties": true,
      "description": "Structured MCTP error data (PROTOCOL.md §9.1).",
      "type": "object",
      "properties": {
        "reason": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "description": "Free-form by-name JSON object.",
          "type": "object",
          "patternProperties": {
            "^(.*)$": {}
          }
        },
        "sessionId": {
          "type": "string"
        },
        "requestId": {
          "type": "string"
        },
        "unmet": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "offered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
