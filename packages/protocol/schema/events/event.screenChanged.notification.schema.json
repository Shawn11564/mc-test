{
  "additionalProperties": false,
  "description": "MCTP notification: event.screenChanged",
  "type": "object",
  "required": [
    "jsonrpc",
    "method",
    "params"
  ],
  "properties": {
    "jsonrpc": {
      "const": "2.0",
      "type": "string"
    },
    "method": {
      "const": "event.screenChanged",
      "type": "string"
    },
    "params": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "sessionId",
        "data"
      ],
      "properties": {
        "sessionId": {
          "description": "Opaque session token from session.create.",
          "type": "string"
        },
        "subscriptionId": {
          "type": "string"
        },
        "seq": {
          "type": "integer"
        },
        "tsMs": {
          "type": "number"
        },
        "data": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "change",
            "kind"
          ],
          "properties": {
            "change": {
              "anyOf": [
                {
                  "const": "opened",
                  "type": "string"
                },
                {
                  "const": "closed",
                  "type": "string"
                },
                {
                  "const": "replaced",
                  "type": "string"
                }
              ]
            },
            "screenId": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "kind": {
              "description": "Active screen kind.",
              "anyOf": [
                {
                  "const": "containerGui",
                  "type": "string"
                },
                {
                  "const": "clientScreen",
                  "type": "string"
                },
                {
                  "const": "hud",
                  "type": "string"
                },
                {
                  "const": "none",
                  "type": "string"
                }
              ]
            },
            "title": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
